# Copy this file to .env and fill values. Do NOT commit your real .env file.

# =========================
# LOCAL DEVELOPMENT (COMPOSE + POSTGRES LOCAL)
# =========================
POSTGRES_DB=icr_connect
POSTGRES_USER=icradmin
POSTGRES_PASSWORD=root
ConnectionStrings__DefaultConnection=Host=icr_db;Port=5432;Database=icr_connect;Username=icradmin;Password=root

JWT_KEY=dev-only-jwt-secret-key-minimum-32-chars!
ROOTUSERNAME=admin
ROOTPASSWORD=admin123
FRONTEND_ORIGIN=http://localhost:3000
ICR_API_URL=http://icr.api:8080
OAUTH_SERVER_URL=http://icr.api:8080

# =========================
# PRODUCTION (SUPABASE / DATABASE_URL)
# =========================
# Use valores fortes/rotacionados em produção
# DATABASE_URL=postgres://user:password@host:5432/database
# JWT_KEY=replace_with_a_secure_random_key
# ROOTUSERNAME=replace_me
# ROOTPASSWORD=replace_with_secure_password
# FRONTEND_ORIGIN=https://app.seudominio.com
# ICR_API_URL=https://api.seudominio.com
# OAUTH_SERVER_URL=https://api.seudominio.com
